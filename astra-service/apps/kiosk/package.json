    "@astra/ui-kit": "workspace:*",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@tanstack/react-query": "^5.59.16",
    "@xstate/react": "^5.0.0",
    "framer-motion": "^11.11.9",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",

    "valtio": "^2.1.2",
    "xstate": "^5.19.0",
    "zod": "^3.23.8",
