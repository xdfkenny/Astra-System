{
  "name": "@astra/shared-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared TypeScript types, Zod schemas, and runtime utilities for Astra-Service.",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./env": "./src/env.ts",
    "./ids": "./src/ids.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "uuidv7": "^1.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
