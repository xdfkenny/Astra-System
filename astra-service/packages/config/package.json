{
  "name": "@astra/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared configuration presets for Astra-Service packages and apps.",
  "exports": {
    "./typescript": "./typescript/base.json",
    "./typescript/base": "./typescript/base.json",
    "./typescript/react": "./typescript/react.json",
    "./typescript/node": "./typescript/node.json",
    "./eslint": "./eslint/index.js",
    "./tailwind": "./tailwind/index.ts",
    "./vite": "./vite/base.config.ts",
    "./vitest": "./vitest/index.ts"
  },
  "files": [
    "typescript",
    "eslint",
    "tailwind",
    "vite",
    "vitest"
