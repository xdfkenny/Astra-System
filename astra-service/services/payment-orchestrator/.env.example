# Payment Orchestrator service configuration
PAYMENT_ORCHESTRATOR_PORT=8086
PAYMENT_ORCHESTRATOR_GRPC_PORT=50086
ASTRA_ENV=development

# Postgres connection string
DATABASE_URL=postgresql://astra:astra@localhost:5432/astra?sslmode=disable

# Redis connection string (used for idempotency-key locks)
REDIS_URL=redis://localhost:6379/0

# NATS JetStream URL
NATS_URL=nats://localhost:4222

# Verifone sidecar transports
# Prefer gRPC to Rust syncd verifone-ffi when set; otherwise fall back to HTTP.
VERIFONE_GRPC_ADDR=
VERIFONE_HTTP_URL=http://localhost:8963

# HMAC secrets
PAYMENT_WEBHOOK_SECRET=astra-dev-webhook-secret-change-in-production
OFFLINE_TOKEN_SECRET=astra-dev-offline-token-secret-change-in-production

# Offline settlement background job (currently exposed as synchronous REST batch)
PAYMENT_SETTLEMENT_ENABLED=false
PAYMENT_SETTLEMENT_INTERVAL=30s

# OpenTelemetry OTLP endpoint (leave empty to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=
