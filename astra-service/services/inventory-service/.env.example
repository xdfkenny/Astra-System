ASTRA_ENV=development
PORT=8082
GRPC_PORT=9092
GRPC_REFLECTION=true

DATABASE_URL=postgresql://astra:astra@localhost:5432/astra?sslmode=disable
REDIS_URL=redis://localhost:6379/0
NATS_URL=nats://localhost:4222

ASTRA_RESERVATION_TTL=5m
ASTRA_RESERVATION_SWEEP=30s
ASTRA_CACHE_TTL=5s

OTEL_EXPORTER_OTLP_ENDPOINT=
