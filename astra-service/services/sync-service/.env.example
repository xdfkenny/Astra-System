# Sync Service — runtime environment variables

# gRPC and HTTP server ports
SYNC_SERVICE_GRPC_PORT=50051
SYNC_SERVICE_HTTP_PORT=8087

# Request timeout for unary RPCs and REST handlers
SYNC_SERVICE_REQUEST_TIMEOUT=30s

# Deployment environment (development, staging, production)
ASTRA_ENV=development

# PostgreSQL connection string
DATABASE_URL=postgresql://astra:astra@localhost:5432/astra?sslmode=disable

# NATS JetStream URL
NATS_URL=nats://localhost:4222

# OpenTelemetry OTLP endpoint (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
