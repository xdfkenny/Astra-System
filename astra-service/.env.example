# ---- Astra-Service local development environment ----
# Copy to .env and fill in real values. Never commit .env.

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=astra
POSTGRES_USER=astra
POSTGRES_PASSWORD=change-me-in-vault
DATABASE_URL=postgresql://astra:change-me-in-vault@localhost:5432/astra?sslmode=disable

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- NATS JetStream ---
NATS_URL=nats://localhost:4222
NATS_CLUSTER_ID=astra-cluster
NATS_JETSTREAM_DOMAIN=kiosk-edge

# --- API Gateway ---
GATEWAY_PORT=8080
GATEWAY_JWT_ISSUER=astra-service
GATEWAY_HMAC_SIGNING_KEY=dev-only-32-byte-minimum-secret-key!!
GATEWAY_RATE_LIMIT_RPS=50
GATEWAY_RATE_LIMIT_BURST=100

# --- Vault ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-only-root-token

# --- Kiosk identity ---
KIOSK_ID=kiosk-sim-001
KIOSK_STORE_ID=store-miami-brickell-01
KIOSK_MESH_PSK=dev-only-mesh-pre-shared-key-32b

# --- P2P sync daemon ---
ASTRA_SYNCD_LISTEN_QUIC=0.0.0.0:4433
ASTRA_SYNCD_MDNS_SERVICE=_astra-sync._udp.local
ASTRA_SYNCD_RAFT_ELECTION_TIMEOUT_MS=1500

# --- Verifone terminal ---
VERIFONE_TERMINAL_IP=192.168.1.50
VERIFONE_TERMINAL_PORT=8963
VERIFONE_MERCHANT_ID=change-me
VERIFONE_TLS_CERT_PATH=/etc/astra/certs/verifone-client.pem

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090
LOKI_URL=http://localhost:3100
