# ── Andino Kiosk Configuration ─────────────────────────────────────
# Copy to .env.andino and fill in your values.
# This kiosk connects to the Andino API for products + user auth.
# The Astra-System backend provides the infrastructure (DB, NATS, Redis).

# Product service mode: "api" (live Andino) or "local" (mock data)
ANDINO_PRODUCT_MODE=api

# Andino API credentials
ANDINO_BASE_URL=https://andinoapp.com
ANDINO_ACCESS_TOKEN=eyJ...your-token-here
ANDINO_SCHOOL_ID=9

# Prototype/test user (for quick demo/development)
ANDINO_PROTOTYPE_USER_ID=8678
ANDINO_PROTOTYPE_PIN=123456

# Admin panel credentials (format: username:pin)
ANDINO_ADMIN_CREDENTIALS=admin:changeme
ANDINO_ADMIN_SESSION_SECRET=replace-with-random-32-char-string

# Hardware (all disabled by default for Docker)
ANDINO_POS_ENABLED=false
ANDINO_PRINTER_ENABLED=false
ANDINO_P2P_ENABLED=false
ANDINO_FACE_ENABLED=false

# Logging
ANDINO_LOG_LEVEL=info
