{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/deepseek-v4-flash-free",
  "small_model": "opencode/deepseek-v4-flash-free",
  "instructions": ["promt.md"],
  "default_agent": "build",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Default orchestrator agent. Delegates coding work to the coder subagent.",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "task": {
          "*": "deny",
          "coder": "allow",
          "explore": "allow",
          "general": "allow",
          "scout": "allow"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "model": "opencode/deepseek-v4-flash-free",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "coder": {
      "description": "Specialized coding subagent using Codestral from Mistral. Invoke with @coder for implementation tasks.",
      "mode": "subagent",
      "model": "mistral/codestral-latest",
      "temperature": 0.3,
      "color": "primary",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "deny",
        "write": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "question": "allow"
      }
    },
    "general": {
      "mode": "subagent",
      "model": "mistral/codestral-latest"
    },
    "explore": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free"
    }
  }
}
