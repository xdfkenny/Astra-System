# Astra-System Environment Configuration
# Copy this to .env and adjust for your deployment.

# Database
POSTGRES_USER=astra
POSTGRES_PASSWORD=astra_secret
POSTGRES_DB=astra_system

# Redis
REDIS_PASSWORD=

# NATS
NATS_PORT=4222

# API Gateway
GATEWAY_PORT=8080

# Kiosk
KIOSK_PORT=80

# Update Channel (stable, beta, canary)
ASTRA_UPDATE_CHANNEL=stable

# Observability
OTEL_ENABLED=false
